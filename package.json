{
  "name": "reactmle",
  "private": true,
  "version": "1.0.1",
  "description": "MCL Studio is a parser-driven Markdown Component Layout Studio with AST inspection, graph visualization, validation, templates, export, and end-to-end QA coverage.",
  "license": "MIT",
  "keywords": [
    "markdown",
    "parser",
    "ast",
    "react",
    "vite",
    "layout-engine",
    "developer-tools",
    "visualization"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "qa:release": "npm run lint && npm run test && npm run test:e2e && npm run build",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "type": "module",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
